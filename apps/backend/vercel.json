{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "/api/index.ts?originalUrl=/api/v1/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.ts?originalUrl=/$1"
    }
  ]
}
