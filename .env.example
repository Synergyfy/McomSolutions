# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Database connection URL (Uncomment and set to connect to Supabase)
# DATABASE_URL="postgresql://postgres:password@db.oyvjdbekepvurmfsmomm.supabase.co:5432/postgres"

# SMTP Email Configuration (Optional, falls back to logging if not set)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@mcomsolutions.com"

# ─── Stripe Payment Configuration ────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── PayPal Payment Configuration ────────────────────────────────────────────
# Get these from: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID="your_paypal_client_id"
PAYPAL_CLIENT_SECRET="your_paypal_client_secret"
# Use 'sandbox' for testing, 'live' for production
PAYPAL_ENV="sandbox"

# ─── HMAC Service-to-Service Auth (Data Sharing API) ────────────────────────
# Shared fallback secret used by all partner services to sign HMAC requests.
# Alternatively, set per-service secrets individually (see below).
SSO_API_SECRET="your-hmac-shared-secret"

# Per-service HMAC secrets (override SSO_API_SECRET for specific services):
# MCOM_MALL_SECRET="mall-hmac-secret"
# MCOM_REWARDS_SECRET="rewards-hmac-secret"
# MCOM_SPIN_SECRET="spin-hmac-secret"
# MCOM_AUDIT_SECRET="audit-hmac-secret"
# MCOM_EXPO_SECRET="expo-hmac-secret"

